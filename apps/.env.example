# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Restart the dev server after changing these.
VITE_FEATURE_LOGIN=0
VITE_FEATURE_NO_SATURDAY_SUNDAY=0
VITE_FEATURE_NO_MULTI_SUBMIT=1
VITE_FEATURE_MINIMUM_USHERS=6
VITE_FEATURE_PPG=0

# ─── Site Information ─────────────────────────────────────────────────────────
VITE_SITE_TITLE='My Church'
PUBLIC_SITE_TITLE='My Church'
PUBLIC_SITE_SUB_TITLE='Parish Name'
PUBLIC_SITE_LOGO='https://example.com/images/logo.png'
PUBLIC_SITE_URL='https://example.com'
PUBLIC_SITE_CHURCH='Church Name'

# ─── Church Configuration ─────────────────────────────────────────────────────
# UUID of the church record in the database.
VITE_CHURCH_ID=00000000-0000-0000-0000-000000000000

# ─── Database ─────────────────────────────────────────────────────────────────
VITE_DATABASE_URL=file:db/lilium.db
DB_FILE_NAME=file:db/lilium.db
# Required only for remote Turso/libSQL databases; leave empty for local SQLite.
VITE_DATABASE_AUTH_TOKEN=

# ─── Logging ──────────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal
VITE_PINO_LEVEL=info

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: npx auth secret
VITE_AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=

# Microsoft Entra ID — https://portal.azure.com/#view/Microsoft_AAD_IAM/ActiveDirectoryMenuBlade/~/RegisteredApps
VITE_AUTH_MICROSOFT_APP_ID=
VITE_AUTH_MICROSOFT_APP_SECRET=
VITE_AUTH_MICROSOFT_ENTRA_APP_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0

# ─── Analytics ────────────────────────────────────────────────────────────────
# PostHog — https://posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Statsig — https://console.statsig.com
VITE_STATSIG_CLIENT_KEY=
